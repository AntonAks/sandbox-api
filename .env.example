# Application
ENV=dev                    # dev | prod
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
UVICORN_WORKERS=2          # number of worker processes (used in prod; local override in compose)

# Database (used by app)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sandbox_api

# Postgres container credentials (used by db service in compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sandbox_api

# JWT — demo only, generate fresh secret for any real deployment
JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Demo user — upserted on app startup. Change here, then `just down && just up`
# to rotate. In CI / AWS deployment, values come from GitHub secrets
# (TF_VAR_DEMO_USER_EMAIL / TF_VAR_DEMO_USER_PASSWORD).
DEMO_USER_EMAIL=dispatcher@example.com
DEMO_USER_PASSWORD=change-me-strong-password
