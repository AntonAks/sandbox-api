# Application
ENV=dev                    # dev | prod
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
UVICORN_WORKERS=2          # number of worker processes (used in prod; local override in compose)

# Database (used by app)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sandbox_api

# Postgres container credentials (used by db service in compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sandbox_api

# JWT — demo only, generate fresh secret for any real deployment
JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
